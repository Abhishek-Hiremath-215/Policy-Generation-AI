# Database - PostgreSQL (Free & Open Source)
DATABASE_URL=postgresql://postgres:system@localhost:5432/policy_ai_db

# LLM Configuration - Ollama (Free & Local)
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# Alternative Ollama Models (all free):
# OLLAMA_MODEL=mistral:latest
# OLLAMA_MODEL=gemma2:9b
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_MODEL=deepseek-r1:14b

# Vector Database - Qdrant (Free & Open Source)
VECTOR_STORE=qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Qdrant can run in two modes:
# 1. Docker (recommended): docker run -p 6333:6333 qdrant/qdrant
# 2. In-memory (for testing): Leave QDRANT_HOST empty

# Application
UPLOAD_DIR=./uploads
POLICY_OUTPUT_DIR=./generated_policies
MAX_UPLOAD_SIZE=104857600  # 100MB
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Security
SECRET_KEY=sufnskldfjvfdknvfdkvnfnjvkfd
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
